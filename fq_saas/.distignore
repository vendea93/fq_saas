# Files excluded from production ZIP build (see scripts/build-zip.sh)
# Anything matching these patterns will be pruned before packaging.

# Dev / test artifacts
test.php
tests/
*.test.php
phpunit.xml*
.phpunit.result.cache

# Source control & editor junk
.git/
.gitignore
.gitattributes
.github/
.idea/
.vscode/
.DS_Store
Thumbs.db

# Docs / changelogs (keep only README.md in production)
CHANGELOG.md
FQ_SAAS_CHANGELOG_KOMENTARZ.md
*.md.bak

# Build meta
scripts/
.distignore
composer.lock

# Vendor dev assets (tests / docs inside vendor packages)
vendor/**/tests/
vendor/**/test/
vendor/**/Tests/
vendor/**/docs/
vendor/**/doc/
vendor/**/examples/
vendor/**/.github/
vendor/**/*.md
vendor/bin/
